# ─────────────────────────────────────────────────────────────
# zotero-ai-toolkit — example environment.
# Copy to `.env` and fill in. `.env` is gitignored; only this
# `.env.example` is committed.
# ─────────────────────────────────────────────────────────────

# ────────────── Zotero ──────────────
# API key from https://www.zotero.org/settings/keys
ZOTERO_API_KEY=
# Numeric user ID (visible in the settings page)
ZOTERO_LIBRARY_ID=
ZOTERO_LIBRARY_TYPE=user
# Use local API (requires Zotero Desktop running). Fallback to web API if false.
ZOTERO_LOCAL_API=true

# ────────────── OpenAI ──────────────
OPENAI_API_KEY=
OPENAI_MODEL_TAG=gpt-4o-mini
OPENAI_MODEL_EXTRACT=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ────────────── Semantic Scholar (optional) ──────────────
# Optional: raises rate limit from 100 req/5min to 1 req/s
SEMANTIC_SCHOLAR_API_KEY=

# ────────────── Paths (inside Docker container) ──────────────
# Comma-separated list of folders with source PDFs
PDF_SOURCE_FOLDERS=/data/folder1,/data/folder2
STAGING_FOLDER=/workspace/staging
STATE_DB=/workspace/state.db
REPORTS_FOLDER=/workspace/reports

# ────────────── Budgets (USD) ──────────────
MAX_COST_USD_TOTAL=10.00
MAX_COST_USD_STAGE_04=2.00
MAX_COST_USD_STAGE_05=1.00

# ────────────── OCR ──────────────
OCR_LANGUAGES=spa+eng
OCR_PARALLEL_PROCESSES=4

# ────────────── Behavior ──────────────
DRY_RUN=false
LOG_LEVEL=INFO
# Required for OpenAlex User-Agent (unlocks 10x rate limit)
USER_EMAIL=

# ────────────── S2 Worker ──────────────
S2_FETCH_INTERVAL_HOURS=6
S2_CANDIDATES_DB=/workspace/candidates.db
# Path to the ChromaDB maintained by zotero-mcp (shared with S3, read-only for S2)
S2_CHROMA_PATH=/workspace/chroma_db
# Zotero collection name where accepted candidates land
S2_ZOTERO_INBOX_COLLECTION=Inbox S2

# ────────────── S2 PDF fetch cascade ──────────────
# Ordered, comma-separated list of sources to try when pushing an accepted
# candidate with a missing PDF. Stops at first success. Remove an entry to
# disable that source. See docs/plan_02_subsystem2.md §10.
S2_PDF_SOURCES=openaccess,doi,annas,libgen,scihub,rss

# ────────────── S2 Dashboard ──────────────
S2_DASHBOARD_HOST=127.0.0.1
S2_DASHBOARD_PORT=8000

# ────────────── S2 Budgets (USD) ──────────────
S2_MAX_COST_USD_DAILY=0.50
S2_MAX_COST_USD_MONTHLY=5.00
